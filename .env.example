# =====================================================
# SHIOL-PLUS Environment Configuration Template
# =====================================================
# Copy this file as .env and add your API keys
# =====================================================

# 🤖 GEMINI AI (Google AI Studio)
# https://makersuite.google.com/app/apikey
GEMINI_API_KEY=

# 🎰 MUSL API (Multi-State Lottery)
MUSL_API_KEY=

# 🔐 JWT SECRET (minimum 32 characters)
JWT_SECRET_KEY=

# 💎 PREMIUM PASS SECRET
PREMIUM_PASS_SECRET_KEY=

# 💳 STRIPE (Payments)
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_ANNUAL=

# 🌍 ENVIRONMENT
ENVIRONMENT=development
DATABASE_PATH=./data/shiolplus.db
PORT=8000
HOST=0.0.0.0
LOG_LEVEL=INFO
